# ─── Database (Docker) ────────────────────────────────────────────────────────
POSTGRES_USER=vsms_user
POSTGRES_PASSWORD=vsms_password
POSTGRES_DB=vsms_db

# Prisma
DATABASE_URL="postgresql://vsms_user:vsms_password@localhost:5432/vsms_db?schema=public"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# JWT — generate strong random secrets for production (min 32 chars)!
JWT_SECRET=change_me_in_production_min32chars_access
JWT_REFRESH_SECRET=change_me_in_production_min32chars_refresh

FRONTEND_URL=http://localhost:5173
